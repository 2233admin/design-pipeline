{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/2233admin/design-pipeline/schemas/source-evidence.schema.json",
  "title": "Host-retrieved upstream source evidence",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "generatedAt", "sources"],
  "properties": {
    "schema": {"const": "design-pipeline.source-evidence.v1"},
    "generatedAt": {"type": "string", "format": "date-time"},
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sourceId", "observedAt"],
        "properties": {
          "sourceId": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
          "observedAt": {"type": "string", "format": "date-time"},
          "revision": {"type": "string", "minLength": 1, "maxLength": 200},
          "version": {"type": "string", "minLength": 1, "maxLength": 100},
          "contentHash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
          "markers": {
            "type": "array",
            "uniqueItems": true,
            "maxItems": 200,
            "items": {"type": "string", "minLength": 1, "maxLength": 200}
          }
        },
        "anyOf": [
          {"required": ["revision"]},
          {"required": ["version"]},
          {"required": ["contentHash"]},
          {"required": ["markers"]}
        ]
      }
    }
  }
}
