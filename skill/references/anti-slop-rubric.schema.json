{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/2233admin/design-pipeline/schemas/anti-slop-rubric.schema.json",
  "title": "Contextual anti-slop rubric",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "version", "updatedAt", "policy", "sources", "rules"],
  "properties": {
    "schema": {
      "const": "design-pipeline.anti-slop-rubric.v1"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "updatedAt": {
      "type": "string",
      "format": "date"
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["blockingSeverities", "contextRule", "preferenceRule"],
      "properties": {
        "blockingSeverities": {
          "type": "array",
          "const": ["hard"]
        },
        "contextRule": {
          "type": "string",
          "minLength": 1
        },
        "preferenceRule": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "url",
          "observedAt",
          "contentHash",
          "intakeState",
          "usage"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "observedAt": {
            "type": "string",
            "format": "date-time"
          },
          "lastModified": {
            "type": "string",
            "format": "date-time"
          },
          "contentHash": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "intakeState": {
            "enum": ["accepted", "accepted-optional", "rejected-duplicate", "watchlist"]
          },
          "usage": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "category",
          "severity",
          "appliesTo",
          "principle",
          "evidenceRequired",
          "exceptionPolicy",
          "sourceIds"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "category": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "severity": {
            "enum": ["hard", "contextual", "preference"]
          },
          "appliesTo": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "principle": {
            "type": "string",
            "minLength": 1
          },
          "evidenceRequired": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "exceptionPolicy": {
            "enum": ["none", "documented-context", "preference-only"]
          },
          "sourceIds": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
            }
          }
        }
      }
    }
  }
}
