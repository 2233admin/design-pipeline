{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/2233admin/design-pipeline/schemas/anti-slop-review.schema.json",
  "title": "Anti-slop review report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "generatedAt",
    "status",
    "target",
    "rubric",
    "summary",
    "findings",
    "acceptedContexts"
  ],
  "properties": {
    "schema": {
      "const": "design-pipeline.anti-slop-review.v1"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "enum": ["pass", "needs-review", "blocked"]
    },
    "target": {
      "type": "object"
    },
    "rubric": {
      "type": "object"
    },
    "summary": {
      "type": "object"
    },
    "findings": {
      "type": "array"
    },
    "acceptedContexts": {
      "type": "array"
    }
  }
}
